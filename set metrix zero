#include<iostream>
using namespace std;

int main() {
    int matrix[3][3] = {
        {1, 1, 1},
        {1, 0, 1},
        {1, 1, 1}
    };

    int n = 3, m = 3;
    bool firstRow = false, firstCol = false;

    // Step 1: check first column
    for(int i = 0; i < n; i++) {
        if(matrix[i][0] == 0) {
            firstCol = true;
            break;
        }
    }

    
    for(int j = 0; j < m; j++) {
        if(matrix[0][j] == 0) {
            firstRow = true;
            break;
        }
    }

    
    for(int i = 1; i < n; i++) {
        for(int j = 1; j < m; j++) {
            if(matrix[i][j] == 0) {
                matrix[i][0] = 0;
                matrix[0][j] = 0;
            }
        }
    }

  
    for(int i = 1; i < n; i++) {
        for(int j = 1; j < m; j++) {
            if(matrix[i][0] == 0 || matrix[0][j] == 0) {
                matrix[i][j] = 0;
            }
        }
    }

    
    if(firstCol) {
        for(int i = 0; i < n; i++) {
            matrix[i][0] = 0;
        }
    }

    
    if(firstRow) {
        for(int j = 0; j < m; j++) {
            matrix[0][j] = 0;
        }
    }

    
    cout << "Result Matrix:\n";
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < m; j++) {
            cout << matrix[i][j] << " ";
        }
        cout << endl;
    }

    return 0;
}
