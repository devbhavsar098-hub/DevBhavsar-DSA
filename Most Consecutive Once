#include <iostream>
using namespace std;

int maxConsecutiveOnes(int arr[], int n) {
    int maxCount = 0;
    int currentCount = 0;

    for(int i = 0; i < n; i++) {
        if(arr[i] == 1) {
            currentCount++;
            if(currentCount > maxCount) {
                maxCount = currentCount;
            }
        } else {
            currentCount = 0;
        }
    }

    return maxCount;
}

int main() {
    int arr[] = {1, 1, 0, 1, 1, 1};
    int n = sizeof(arr) / sizeof(arr[0]);

    cout << "Max consecutive ones: " << maxConsecutiveOnes(arr, n);

    return 0;
}
