#include <iostream>
using namespace std;

int main()
{
    int n, i, flag = 0;

    cout << "Enter a number: ";
    cin >> n;

    if(n <= 1)
    {
        cout << "Not a Prime Number";
    }
    else
    {
        for(i = 2; i < n; i++)
        {
            if(n % i == 0)
            {
                flag = 1;
                break;
            }
        }

        if(flag == 0)
            cout << "Prime Number";
        else
            cout << "Not a Prime Number";
    }

    return 0;
}
