#include <iostream>
using namespace std;

int main() {
    int arr[] = {1,2,3,1,2,1,2,1};
    int n = 8;

    int count1 = 0, count2 = 0;
    int ele1 = -1, ele2 = -1;

    // Find candidates
    for(int i = 0; i < n; i++) {
        if(arr[i] == ele1) count1++;
        else if(arr[i] == ele2) count2++;
        else if(count1 == 0) {
            ele1 = arr[i];
            count1 = 1;
        }
        else if(count2 == 0) {
            ele2 = arr[i];
            count2 = 1;
        }
        else {
            count1--;
            count2--;
        }
    }

    // Verify
    count1 = count2 = 0;
    for(int i = 0; i < n; i++) {
        if(arr[i] == ele1) count1++;
        else if(arr[i] == ele2) count2++;
    }

    if(count1 > n/3) cout << ele1 << " ";
    if(count2 > n/3) cout << ele2;

    return 0;
}
